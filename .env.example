NEXT_PUBLIC_BASE_PATH=/portfolio

# Copy this file to .env.local and fill in the values.
# Do NOT commit .env.local — it contains secrets.

# ─── Frontend: where the contact form POSTs to ─────────────────────────────
# In production (GitHub Pages) this MUST be the Cloudflare Worker URL,
# because GH Pages can't run /api/contact.
# Leave blank in dev to fall back to the local Next.js API route.
NEXT_PUBLIC_CONTACT_ENDPOINT=https://portfolio-contact.<your-subdomain>.workers.dev

# ─── Below: only used by the local /api/contact dev route ──────────────────
# (In production these live as Cloudflare Worker secrets, set via
#  `wrangler secret put`, not in this file.)

# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here

# Where contact form submissions get delivered.
CONTACT_RECIPIENT=zia.rehman.web@gmail.com

# Sender address shown to recipients. Must be a Resend-verified domain
# OR keep the default "onboarding@resend.dev" for testing.
# Note: onboarding@resend.dev only delivers to your own verified Resend address.
RESEND_FROM=Portfolio Contact <onboarding@resend.dev>
